{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframelabs.org/schemas/cricore-contract-0.1.0.json",
  "title": "CRI-CORE Compiled Contract Artifact",
  "description": "Deterministic governance contract artifact consumed by the CRI-CORE enforcement pipeline.",
  "type": "object",

  "required": [
    "contract_id",
    "contract_version"
  ],

  "properties": {

    "contract_id": {
      "type": "string",
      "description": "Unique identifier for the compiled governance contract."
    },

    "contract_version": {
      "type": "string",
      "description": "Semantic version of the compiled contract artifact.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "authority_requirements": {
      "type": "object",
      "description": "Structural authority expectations for mutation approval.",
      "properties": {

        "proposer_role": {
          "type": "string"
        },

        "reviewer_roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },

        "separation_of_duties": {
          "type": "boolean"
        }

      },
      "additionalProperties": false
    },

    "artifact_requirements": {
      "type": "object",
      "description": "Artifact binding requirements for mutation proposals.",
      "properties": {

        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }

      },
      "additionalProperties": false
    },

    "stage_requirements": {
      "type": "object",
      "description": "Structural stage constraints enforced by the kernel.",
      "properties": {

        "allowed_transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {

              "from": {
                "type": "string"
              },

              "to": {
                "type": "string"
              }

            },
            "additionalProperties": false
          }
        }

      },
      "additionalProperties": false
    },

    "invariants": {
      "type": "object",
      "description": "Structural invariants required by the contract.",
      "properties": {

        "separation_of_duties": {
          "type": "boolean"
        }

      },
      "additionalProperties": false
    }

  },

  "additionalProperties": false
}
